STRINGTABLE 
{
 PROGRAM_TITLE, "Select executable file"
 PROGRAM_FILTER, "Executable file|*.exe|"
 BITMAP_TITLE, "Select bitmap for wallpaper"
 BITMAP_FILTER, "Windows Bitmaps (*.bmp;*.jpg)|*.bmp;*.jpg|"
 SAVER_TITLE, "Select Screen Saver"
 SAVER_FILTER, "Screen Saver|*.scr|"
}


STRINGTABLE 
{
 IDC_PARSE_AUTO, "Parses the DOS autoexec.bat file for setting the environment"
 IDC_WAIT_AUTO, "Wait for execution of the startup file before starting the NT Shell"
 GLOBAL_CONFIG, "Opens global configuration dialog.\nFor Administrators only"
}

STRINGTABLE
{
	IDE_WALLPAPER,		"Sets the background bitmap of the logon screen"
	IDPB_BROWSE_WALL,	"Selects the background bitmap"
	IDC_TILE_WALL,		"Tile to background bitmap over the entire screen"
	IDE_SCREEN_SAVER	"Sets the screen saver during logon"
	IDPB_BROWSE_SAVER	"Selects the screen saver"
	IDE_SAVER_TIMEOUT	"Set the timeout in minutes for the screen saver to start"
}

